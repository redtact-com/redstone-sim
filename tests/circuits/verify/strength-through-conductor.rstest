# 信号強度は動力源化 (導体の強充電) を経ても維持される (02 §5.2 [要検証]→確定)。
# 典拠 (26.2 デコンパイル): SignalGetter.getSignal =
#   isRedstoneConductor(pos) ? max(state.getSignal, getDirectSignalTo(pos)) : state.getSignal。
#   getDirectSignalTo は隣接 6 方向の getDirectSignal の max を「減衰なし」で取る。
#   → 強充電された導体は源の強度をそのまま再放出する。−1 の減衰はダスト間
#   (RedStoneWireBlock.calculateTargetStrength = 隣接ワイヤ −1) だけで発生する。
#
# 導出 (spec 先行): レバー→ダスト 4 マス減衰 15,14,13,12 → コンパレーター(compare) 背面 12
#   → 出力 12 の direct signal が石を 12 で強充電 (ComparatorBlock.getDirectSignal=outputPower)
#   → 石の隣ダストは max(…, getDirectSignalTo=12) = 12 (維持) → 次ダスト 11 (ダスト減衰再開)。
# 実行して照合 → 一致 (sim=spec)。導体越しに 12→12 (減衰なし)、その先で 12→11。
meta {
  name: 信号強度は導体の強充電を経ても維持 (減衰なし)
  ref: 02 §5.2 / 26.2 SignalGetter.getSignal(導体分岐 max, getDirectSignalTo 減衰なし)
}

circuit {
  (0,0,0)..(8,0,0) stone
  (0,1,0) lever[face=floor,facing=north,powered=false]
  (1,1,0)..(4,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (5,1,0) comparator[facing=west,mode=compare,powered=false]
  (6,1,0) stone                                                                  # 導体 (コンパレーターが強充電)
  (7,1,0)..(8,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
}

inputs {
  t2 use (0,1,0)
}

state {
  t0 (7,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  t8 (4,1,0) redstone_wire[east=side,north=none,power=12,south=none,west=side]   # コンパレーター背面入力 = 12
  t8 (5,1,0) comparator[facing=west,mode=compare,powered=true]
  t8 (7,1,0) redstone_wire[east=side,north=none,power=12,south=none,west=side]   # 導体越しに 12 維持 (減衰なし)
  t8 (8,1,0) redstone_wire[east=side,north=none,power=11,south=none,west=side]   # ダスト間で 11 に減衰
}
