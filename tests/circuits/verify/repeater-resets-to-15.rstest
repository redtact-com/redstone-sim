# リピーターは入力強度に関係なく出力を 15 にリセットする (02 §5.1 [要検証]→確定)。
# 典拠 (26.2 デコンパイル): DiodeBlock.getOutputSignal は定数 15 を返し、RepeaterBlock は
# これを override しない。ownSignal = POWERED ? getOutputSignal(=15) : 0。
# → 背面入力が減衰して 10 でも、前面出力は 15 に「増幅/リセット」される。
#
# 導出 (spec 先行): レバー ON → ダスト 6 マスで 15,14,13,12,11,10 と減衰
#   (RedStoneWireBlock.calculateTargetStrength = 隣接ワイヤ −1)。リピーター背面入力 = 10。
#   リピーター出力 = 15 (定数) → 直後のダストは 15、次で 14。
# 実行して照合 → 一致 (sim=spec)。入力 10 < 出力 15 が「リセット」の証拠。
meta {
  name: リピーターは出力を 15 にリセット (アナログ非保持)
  ref: 02 §5.1 / 26.2 DiodeBlock.getOutputSignal(定数15) / RepeaterBlock 非override
}

circuit {
  (0,0,0)..(9,0,0) stone
  (0,1,0) lever[face=floor,facing=north,powered=false]
  (1,1,0)..(6,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (7,1,0) repeater[delay=1,facing=west,locked=false,powered=false]
  (8,1,0)..(9,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
}

inputs {
  t2 use (0,1,0)
}

# 部分一致。リピーターは STC (scheduled tick) 素子: 予約(n.2) → 2gt後 実行(n). priority -1。
trace {
  2gt[PI]: Le{n.0}
  2gt[ST]: Re(n.2) p-1
  4gt[ST]: Re{n.2}
}

state {
  t0 (8,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  t8 (6,1,0) redstone_wire[east=side,north=none,power=10,south=none,west=side]   # 背面入力 = 10 (減衰後)
  t8 (7,1,0) repeater[delay=1,facing=west,locked=false,powered=true]
  t8 (8,1,0) redstone_wire[east=side,north=none,power=15,south=none,west=side]   # 出力 = 15 (リセット, > 入力 10)
  t8 (9,1,0) redstone_wire[east=side,north=none,power=14,south=none,west=side]
}
