# ダストカット連鎖 (#51): ピストンが信号源 (redstone_block) をダスト線から引き離し、
# 下流のトポロジー (通電) を変える。既存 dynamic-connect-push は「押して繋ぐ」方向、
# こちらは「押して切る」方向で非重複。トポロジー再計算が移動と同 tick (within-tick) で起き、
# ランプ消灯だけが素子固有の 4gt 遅延に従うことを検証する。
#
# 仕様クロスチェック (02 §6 piston / §4.2 wire / §6 lamp [確定] / #51):
#   (a) 導出: 初期は rblock(1,1,0) が隣接ダスト (1,1,1) を strong 15 で給電 → ダスト線点灯・
#       ランプ lit。ピストン (0,1,0 facing east) 伸長で rblock は (1,1,0)→(2,1,0) へ移動し、
#       (1,1,1) と非隣接になる → §6 piston の afterPistonMove が移動と同 tick に接続/電力を
#       再計算 (vanilla updateShape 相当) → ダスト即 0 (within-tick カット)。カット自体は
#       rblock が (1,1,0) を離れて moving_piston になる t3 で成立 (透過セルは給電しない)。
#       ランプは §6 lamp より ON は即時・OFF は 4gt 遅延 → t3 でダスト 0 でも lit は t3+4=t7 に消灯。
#       player-action 起動なので t2→t3(BE 伸長=カット)→t5(rblock 確定)。
#   (b) → (c) → (d): sim=仕様が一致 (PASS)。gt オフセット無し。
#   ※ (1,1,1) は moving_piston ではなく実在ダスト → power 断言可。過渡 moving_piston (1,1,0/2,1,0)
#     は断言しない。
meta {
  name: ダストカット (ピストンが信号源を引き離し下流を消灯・カットは同 tick/消灯は 4gt)
  ref: 02 §6 piston (afterPistonMove の within-tick 再計算) / §6 lamp (OFF 4gt) / #51
}

circuit {
  (-2,0,0)..(2,0,0) stone
  (1,0,1) stone
  (1,0,2) stone
  (1,0,3) stone
  (-2,1,0) lever[face=floor,facing=north,powered=false]
  (-1,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (0,1,0) piston[extended=false,facing=east]
  (1,1,0) redstone_block
  (1,1,1) redstone_wire[east=none,north=side,power=0,south=side,west=none]
  (1,1,2) redstone_wire[east=none,north=side,power=0,south=side,west=none]
  (1,1,3) redstone_lamp[lit=false]
}

inputs {
  t2 use (-2,1,0)
}

ticks 10

# strict: 伸長 (3gt[BE]) と同 tick にランプの OFF 予約 (3gt[ST] La(f.4)) が出る = ダストが
# その tick に 0 になった証拠。OFF 実行は +4gt (7gt[ST] La{f.4}) = ランプ固有の消灯遅延。
# #80: moving_piston 確定 (Rb/Ph) を TE 相へ移行したことによる更新 (ST 相予約行消滅・実行 ST→TE)。
#      ランプの OFF 予約/実行 (La) は素子の tile tick なので ST のまま不変。
trace strict {
  2gt[PI]: Le{n.0}
  2gt[BE]: Pi(p.s)
  3gt[BE]: Pi{p.0}
  3gt[ST]: La(f.4) p0
  5gt[TE]: Rb{c.2}
  5gt[TE]: Ph{c.2}
  7gt[ST]: La{f.4}
}

state {
  t0 (1,1,1) redstone_wire[east=none,north=side,power=15,south=side,west=none]   # rblock が給電
  t0 (1,1,3) redstone_lamp[lit=true]
  t3 (0,1,0) piston[extended=true,facing=east]                                   # 伸長開始
  t3 (1,1,1) redstone_wire[east=none,north=side,power=0,south=side,west=none]    # 同 tick でカット
  t3 (1,1,3) redstone_lamp[lit=true]                                            # 消灯はまだ (4gt 遅延)
  t5 (2,1,0) redstone_block                                                     # rblock 最終位置
  t7 (1,1,3) redstone_lamp[lit=false]                                          # 4gt 後に消灯
  t10 (2,1,0) redstone_block                                                    # 恒久変位
  t10 (1,1,3) redstone_lamp[lit=false]
}
