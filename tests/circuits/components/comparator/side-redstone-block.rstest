# コンパレーター側面入力 = レッドストーンブロック (15) は compare/subtract 両モードで効く
# (02 §6 comparator side [確定: 15w47a 追加、Java 限定])。
# 3 系統で side=redstone_block(15) を検証:
#   A (compare, back=13): side(15) > back(13) → 出力 0 (点灯しない)。
#   B (subtract, back=15): 15 - 15 = 0 → 出力 0 (点灯しない)。
#   C (compare, back=15): side(15) は back(15) を超えない → 出力 = back = 15 (点灯する)。
# A/B が「side が効いている (0 に潰す)」証拠、C が「両モードで side が back と同じでも通す」証拠。
meta {
  name: コンパレーター側面 redstone_block=15 (compare/subtract 両効)
  ref: 02 §6 comparator (side redstone_block=15, 両モード) / fixture comparator-side-redstone-block
}

fixture comparator-side-redstone-block

state {
  # A: compare, back=13 < side=15 → 側面が勝ち出力 0 (最後まで点かない)
  t8  (4,1,0) comparator[facing=west,mode=compare,powered=false]
  t8  (5,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  # B: subtract, back=15 - side=15 = 0 → 点かない
  t8  (2,1,3) comparator[facing=west,mode=subtract,powered=false]
  t8  (3,1,3) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  # C: compare, back=15 = side=15 (超えない) → 出力 = back = 15 (点灯)
  t8  (2,1,6) comparator[facing=west,mode=compare,powered=true]
  t8  (3,1,6) redstone_wire[east=side,north=none,power=15,south=none,west=side]
}
