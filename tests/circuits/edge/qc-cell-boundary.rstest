# 準接続 (QC) セルの境界: ピストンは pos.above() (+1 のマス) の受電だけを見る
# (02 §5.3 QC / §6 piston getNeighborSignal = 「1 個上のマスの hasSignal」[確定])。
# 第一弾 components/piston/quasi-connectivity は「+1 セル受電で伸長」を pin する。
# 本ケースは QC が届く高さの**境界**を対で断言する:
#   P1: redstone_block を +2 (piston(0,1,0) の 2 個上=(0,3,0)) に置く。
#       → QC セル (0,2,0) はその真上 rblock から受電 → ピストン伸長 (○)。
#   P2: redstone_block を +3 ((5,4,0)) に置く。→ 受電するのは +2 セル (5,3,0) だけで、
#       QC セル (5,2,0) は受電しない → ピストン伸長しない (−)。
#   ∴ QC の判定は「ちょうど 1 個上 (pos.above())」に限られる (+2 セルは見ない)。
# 期待値は §5.3/§6 の getNeighborSignal ([確定] pos.above() のみ) から先に導出 → sim で照合 → 一致 (PASS)。
meta {
  name: QC セル境界 (+2 で伸長する・+3 では伸長しない)
  ref: 02 §5.3 QC / §6 piston (getNeighborSignal = pos.above() の hasSignal [確定])
}

circuit {
  # P1: rblock を +2 に置く → QC セル (0,2,0) を給電 → 伸長
  (0,0,0) stone
  (0,1,0) piston[extended=false,facing=east]
  (0,3,0) redstone_block
  # P2: rblock を +3 に置く → +2 セルのみ給電, QC セル (5,2,0) は非給電 → 伸長せず
  (5,0,0) stone
  (5,1,0) piston[extended=false,facing=east]
  (5,4,0) redstone_block
}

# 静的だが BUD: QC で動力源化しても、伸長 BE は初期 settle でキューされ翌 tick に発火する
# (§4.3 powered≠activated)。t0 は両方 retracted、伸長判定後 (t6) に対で断言する。
state {
  # t0: 両方まだ retracted (QC 動力源化済みだが BE 未発火 = BUD)
  t0 (0,1,0) piston[extended=false,facing=east]
  t0 (5,1,0) piston[extended=false,facing=east]
  # t6: P1 のみ伸長 (head 出現) / P2 は伸長しない (head なし)
  t6 (0,1,0) piston[extended=true,facing=east]
  t6 (1,1,0) piston_head[facing=east,short=false,type=normal]    # P1: +2 の QC で伸長
  t6 (5,1,0) piston[extended=false,facing=east]                  # P2: +3 は QC に届かず伸長せず
  t6 (6,1,0) air                                                 # P2 の head は出ない
}

# strict: verbose=false の全 process 行。伸長するのは P1 の 1 台だけ = Pi の BE が 1 系列のみ
# (P2 は BE を一切出さない) ことを固定する。gt は入力起点でなく settle でキューされた BE の
# 実 gt (start delay 1gt 相当で gt1 発火)。検証対象は「BE 系列が 1 本のみ」であって gt 絶対値でない。
trace strict {
  1gt[BE]: Pi{p.0}
  1gt[ST]: Ph(c.2) p0
  3gt[ST]: Ph{c.2}
}
