# コンパレーター側面入力は左右の max を取る (02 §6 comparator: side = max(side_L, side_R) [確定])。
# 第一弾 components/comparator/side-input-reject は「片側 1 本」の受理規則を pin する。
# 本ケースは**両側面に異なる値**を与え、subtract 出力が min でも和でもなく max で決まることを断言する。
# 構成: 背面 = redstone_block (15)。側面 north = ダスト 14 / 側面 south = ダスト 13。
#   subtract 出力 = back - max(L,R) = 15 - max(14,13) = 15 - 14 = 1。
#   もし min を取れば 15-13=2、和なら 15-27→0(clamp)。∴ 出力 1 は max の一意な証拠。
# 期待値は 02 §6 の calculateOutputSignal ([確定] side=max(L,R)) から先に導出 → sim で照合 → 一致 (PASS)。
meta {
  name: コンパレーター側面 max(L,R) (両側 14/13 → 15-max=1)
  ref: 02 §6 comparator (side = max(side_L, side_R), subtract=back-side [確定])
}

circuit {
  (0,0,-3)..(5,0,4) stone
  (2,1,0) redstone_block                                            # 背面 = 15 (定数)
  (3,1,0) comparator[facing=west,mode=subtract,powered=false]       # facing=west: 背面=west(rblock), 側面=north/south
  (4,1,0)..(5,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]   # 出力=east
  # 側面 north を 14 にする源 (rblock→ダスト 1 マスで 14)
  (3,1,-3) redstone_block
  (3,1,-2)..(3,1,-1) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  # 側面 south を 13 にする源 (rblock→ダスト 2 マスで 13)
  (3,1,4) redstone_block
  (3,1,1)..(3,1,3) redstone_wire[east=side,north=none,power=0,south=none,west=side]
}

# 定常回路 (入力なし)。初期 settle 後の t0 断面で確認する。
state {
  # 両側面に異なる値 (対で断言): 14 と 13
  t0 (3,1,-1) redstone_wire[east=none,north=side,power=14,south=side,west=none]   # 側面 north = 14 (大きい方)
  t0 (3,1,1)  redstone_wire[east=none,north=side,power=13,south=side,west=none]   # 側面 south = 13 (小さい方)
  t0 (3,1,0)  comparator[facing=west,mode=subtract,powered=true]
  # 出力 = 15 - max(14,13) = 1 (min なら 2, 和なら 0。1 は max の一意な証拠)
  t0 (4,1,0)  redstone_wire[east=side,north=none,power=1,south=none,west=side]
  t0 (5,1,0)  redstone_wire[east=side,north=none,power=0,south=none,west=side]
}
