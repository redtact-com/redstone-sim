# ダスト形状遷移の瞬間と給電方向の切り替え (#51 動的接続 / 02 §5.4 / 11 §2 [確定])。
# 第一弾 components/wire/dot-cross-powering は「静的 cross の給電」を pin する。
# 本ケースはピストンで信号源をダスト隣へ**押し込む**ことで形状が cross→直線に遷移し、
# それに伴い給電方向が切り替わることを対で断言する (#51 の接続動的再計算):
#   - 初期: 孤立ダスト (0,1,0) は物理接続 0 → cross (11 §1.2)。電源なしで power=0、両ランプ消灯。
#   - piston が redstone_block を west 隣 (-1,1,0) へ押し込む → ダストは west 接続 1 本を得て
#     直線 E-W へ自動拡張 (11 §1.2: 1 本→反対側も SIDE)。power=15 になる。
#   - 直線 E-W は「延長端 (east) には給電する」が「垂直 (north) には給電しない」(11 §2 マトリクス)。
#     → east ランプ点灯 / north ランプ消灯 (対で断言)。
# 期待値は 11 §1.2/§2 の [確定] マトリクスから先に導出 → sim で照合 → 一致 (PASS)。
meta {
  name: ダスト形状遷移 cross→直線 と給電方向の切替 (延長端○/垂直−)
  ref: 02 §5.4 / 11 §1.2 (1本→直線拡張) / 11 §2 (形状×方向マトリクス) / #51 動的接続
}

circuit {
  (-4,0,0) stone
  (-3,0,0) stone
  (0,0,0)  stone
  (-4,1,0) lever[face=floor,facing=north,powered=false]
  (-3,1,0) piston[extended=false,facing=east]
  (-2,1,0) redstone_block                                            # 押し込む信号源
  (0,1,0)  redstone_wire[east=side,north=side,power=0,south=side,west=side]   # 孤立 = cross
  (1,1,0)  redstone_lamp[lit=false]                                  # east = 直線化後の延長端
  (0,1,-1) redstone_lamp[lit=false]                                  # north = 直線に対し垂直
}

inputs {
  t2 use (-4,1,0)   # レバー ON → piston 伸長 → rblock を (-1,1,0) へ
}

# piston は BEC: 予約 (p.s) → 実行 (p) → rblock 確定 (c.2) を +2gt。rblock 確定 (t5) と同 tick で
# ダストが接続を張り替え給電される (within-tick)。gt は settle オフセット込みの実出力。
# #80: moving_piston 確定を TE 相へ移行したことによる更新 (rblock 確定 5gt[ST]→5gt[TE])。
trace {
  2gt[PI]: Le{n.0}
  2gt[BE]: Pi(p.s)
  5gt[TE]: Rb{c.2}      # rblock 確定 (BlockEntity 相) = この tick で形状遷移 + 給電が成立
}

state {
  # 初期: 孤立ダストは cross、電源なしで両ランプ消灯
  t0 (0,1,0)  redstone_wire[east=side,north=side,power=0,south=side,west=side]   # cross (物理接続 0)
  t0 (1,1,0)  redstone_lamp[lit=false]
  t0 (0,1,-1) redstone_lamp[lit=false]
  # 遷移後 (t6): rblock 隣接 → 直線 E-W へ拡張 + power=15
  t6 (-1,1,0) redstone_block                                                    # 押し込み完了
  t6 (0,1,0)  redstone_wire[east=side,north=none,power=15,south=none,west=side]  # cross→直線 E-W
  # 給電方向の切替 (対で断言): 延長端は点灯・垂直は消灯
  t6 (1,1,0)  redstone_lamp[lit=true]    # east (延長端) → 給電
  t6 (0,1,-1) redstone_lamp[lit=false]   # north (垂直) → 非給電
}
