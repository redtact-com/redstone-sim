# インスタントワイヤ: dust の 0 遅延 (PLC) 伝播。15 マスの dust 直線を lever ON と
# 同一 gt で全マスが最終 power (減衰 1/マス) に到達する。tile tick を 1 件も予約しない
# ことを trace strict で固定する (= 即時伝播の証拠)。
# 期待は 02 §5.1 (0-15, 減衰 1/ブロック) + §6 wire (PLC 即時) から先に導出:
#   dust(k) の power = 15-(k-1) が「lever を押した tick t2 の断面」で成立するはず。
meta {
  name: インスタントワイヤ (dust 0 遅延伝播)
  ref: 02 §5.1 信号減衰 / §6 wire (PLC 即時伝播) / §1.3 PLC
}

circuit {
  (0,0,0)..(15,0,0) stone          # 回路床
  (0,0,1)..(15,0,1) stone          # プレイヤ床
  (0,1,0) lever[face=floor,facing=north,powered=false]
  (1,1,0)..(14,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (15,1,0) redstone_wire[east=none,north=none,power=0,south=none,west=side]
}

inputs {
  t2 use (0,1,0)                   # ON
  t8 use (0,1,0)                   # OFF
}

# strict: verbose=false の全 process 行。PI(レバー) 2 行のみ = dust 伝播で ST を
# 一切予約しない = 全 15 マスの power 確定が lever 押下と同一 tick で完結する。
trace strict {
  2gt[PI]: Le{n.0}
  8gt[PI]: Le{f.0}
}

state {
  t1  (15,1,0) redstone_wire[east=none,north=none,power=0,south=none,west=side]   # 直前は 0
  # lever ON の tick t2 で、15 マス先まで同一 tick で最終 power に到達 (減衰 1/マス):
  t2  (0,1,0)  lever[face=floor,facing=north,powered=true]
  t2  (1,1,0)  redstone_wire[east=side,north=none,power=15,south=none,west=side]  # 15
  t2  (8,1,0)  redstone_wire[east=side,north=none,power=8,south=none,west=side]   # 15-7=8
  t2  (15,1,0) redstone_wire[east=none,north=none,power=1,south=none,west=side]   # 15-14=1
  t8  (15,1,0) redstone_wire[east=none,north=none,power=0,south=none,west=side]   # OFF も即時
}
