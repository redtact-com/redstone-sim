# 2 ホッパー ping-pong クロック: A(east)⇄B(west) が 1 個を交換。A 背面コンパレーターが
# 充填 (信号 1 ⇔ 0) を読んでトグルする。lever(A 南の block 上)で A を初期ロック
# (enabled=false, settled)、t2 で解除して発振。
# ★ 周期は **7gt 半周期 (14gt)**。vanilla HopperBlockEntity.add の -1 補正 (押し込み先が
#   同gt に既に tick 済みなら setCooldown(8-1)=7、未 tick でも自 tick で -1 され実効 7gt)
#   により、1 個が A→B→A と **7gt おき**に移動する → コンパレーター powered は 14gt 周期。
#   実機 microTiming/実機 fixture (hopper-2clock.json) と一致 (#89 で flat-8 の 16gt を修正)。
# ※ trace gt は settle(flush) 2gt 分オフセット (実出力から書き写し)。検証対象は
#   コンパレーター再計算間隔 7gt と powered の 14gt 周期。
meta {
  name: 2 ホッパークロック (7gt 転送 → 14gt 周期)
  ref: 02 §6 hopper [setCooldown(8) の -1 補正 = 実効7gt / eject→suck / NC ロック] / #89
}

circuit {
  (0,0,0)..(2,0,1) stone                                       # 床
  (0,0,2) stone                                                # プレイヤ床
  (0,1,0) comparator[facing=east,mode=compare,powered=true]    # A を背面(east)読み
  (1,1,0) hopper[enabled=true,facing=east] items=1             # A (item=1)
  (2,1,0) hopper[enabled=true,facing=west] items=0             # B
  (1,1,1) stone                                                # ロック块 (A の南)
  (1,2,1) lever[face=floor,facing=north,powered=true]          # gate: block を強充電で A ロック
}

inputs {
  t2 use (1,2,1)                                               # gate 解除 → 発振開始
}

ticks 40

# 部分一致 (settle 2gt オフセット済み)。Co(c.2) の予約が 7gt おきに現れる = 転送が
# 実効 7gt ごとに A の充填を変えコンパレーターが再計算している証拠 (#89 の -1 補正)。
trace {
  4gt[PI]: Le{f.0}                                             # gate 解除 (input t2 + settle 2gt)
  5gt[ST]: Co(c.2) p0                                          # A→B で A 空 → 再計算予約
  7gt[ST]: Co{c.2}
  12gt[ST]: Co(c.2) p0                                         # 7gt 後: B→A で A 充填 → 再計算
  14gt[ST]: Co{c.2}
  19gt[ST]: Co(c.2) p0                                         # さらに 7gt 後
  21gt[ST]: Co{c.2}
}

state {
  t0  (0,1,0) comparator[facing=east,mode=compare,powered=true]    # 初期: A に item, ロック中
  t0  (1,1,0) hopper[enabled=false,facing=east]                    # A はロック (enabled=false)
  t2  (1,1,0) hopper[enabled=true,facing=east]                     # 解除
  t7  (0,1,0) comparator[facing=east,mode=compare,powered=false]   # item が B へ (A 空)
  t14 (0,1,0) comparator[facing=east,mode=compare,powered=true]    # 7gt 後 A へ戻る
  t21 (0,1,0) comparator[facing=east,mode=compare,powered=false]   # 14gt 周期で再び B へ
}
