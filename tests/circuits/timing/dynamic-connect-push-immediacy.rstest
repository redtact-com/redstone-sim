# 0-tick 系の前提となる within-tick 即時性 (動的接続 #51、fixture dynamic-connect-push 土台)。
# 粘着ピストンが redstone_block をダスト線の隣へ押し込む。ブロックが確定する tick と、
# ダストが接続を張り替えて給電される tick が **同一 tick** であることを固定する
# (接続再計算・電力伝播に遅延が無い = 0-tick 回路が成立する前提)。
#
# 仕様クロスチェック (02 §6 piston / §4.2 wire / #51):
#   moving_piston の確定は BE 予約 → +2gt の BlockEntity (TE) 相 tick。確定と同時に
#   afterPistonMove が接続形状を張り替え (vanilla updateShape 相当) → ダストが T 字化して
#   給電される。sim では確定(t5)と再接続+給電(t5)が同 tick、引き抜き(t15)の切断も同 tick。
#   sim=仕様が一致 (PASS)。gt オフセット無し。
#   ※ 部分一致トレース + state で「同 tick 内即時性」を固定。実機系列一致は
#     fixtures.test.ts (dynamic-connect-push) が別途担保。
# #80: moving_piston 確定を TE 相へ移行したことによる更新 (ST 相 tile tick の予約行消滅・確定 ST→TE)。
meta {
  name: 動的接続の within-tick 即時性 (0-tick 前提)
  ref: 02 §6 piston / §4.2 / #51 / fixture dynamic-connect-push
}

fixture dynamic-connect-push

trace {
  2gt[PI]: Le{n.0}
  2gt[BE]: Pi(p.s)         # 伸長 BE 予約
  3gt[BE]: Pi{p.0}         # BE 実行 (start delay 1gt)
  5gt[TE]: Rb{c.2}         # redstone_block 確定 (BlockEntity 相。この tick で下の state が同時成立)
}

state {
  # 確定 tick (t5) と同一 tick でダストが T 字化 + 給電 (within-tick 即時性)。
  # (t3 の moving_piston は過渡状態のため state 断言不可 — トレースの Rb(c.2)/Rb{c.2} で追う)
  t5 (2,1,1) redstone_block
  t5 (2,1,0) redstone_wire[east=side,north=none,power=15,south=side,west=side]
  # 引き抜き: 切断も同 tick (lever off t14 → 移動 t15 → ダスト即 0)
  t15 (2,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  t17 (2,1,3) sticky_piston[extended=false,facing=north]          # 収縮完了
}
