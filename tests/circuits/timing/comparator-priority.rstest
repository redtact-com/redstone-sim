# コンパレーター TickPriority -1 / 0 を固定する (02 §2.2 [確定])。
# 2 本の独立回路を別 tick で駆動して strict トレースを混ざらせない。
#   z=0 (t2 駆動): comp の front がリピーター(別ダイオード) → priority -1
#   z=3 (t10 駆動): comp の front がワイヤ                   → priority 0
#
# 仕様クロスチェック (02 §2.2): コンパレーターは「出力先が別ダイオードの側面/背面 → -1、
# その他 → 0」。デコンパイル典拠 ComparatorBlock.checkTickOnNeighbor
# (scheduleTick(2, shouldPrioritize ? -1 : 0))。sim=仕様が一致 (PASS)。
# gt オフセット無し。検証対象は p 値 (と comp が 2gt 固定遅延で反応する順序)。
meta {
  name: コンパレーター priority -1/0
  ref: 02 §2.2 / §6 comparator / ComparatorBlock.checkTickOnNeighbor / 08
}

circuit {
  (0,0,0)..(4,0,0) stone
  (0,0,3)..(3,0,3) stone
  # z=0: front=repeater(diode) → -1
  (0,1,0) lever[face=floor,facing=north,powered=false]
  (1,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (2,1,0) comparator[facing=west,mode=compare,powered=false]
  (3,1,0) repeater[delay=1,facing=west,locked=false,powered=false]
  (4,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  # z=3: front=wire → 0
  (0,1,3) lever[face=floor,facing=north,powered=false]
  (1,1,3) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (2,1,3) comparator[facing=west,mode=compare,powered=false]
  (3,1,3) redstone_wire[east=side,north=none,power=0,south=none,west=side]
}

inputs {
  t2  use (0,1,0)     # z=0 chain 駆動
  t10 use (0,1,3)     # z=3 chain 駆動
}

ticks 14

trace strict {
  2gt[PI]: Le{n.0}
  2gt[ST]: Co(c.2) p-1     # z=0 comp: front=repeater(diode) → -1
  4gt[ST]: Co{c.2}
  4gt[ST]: Re(n.2) p-1     # 下流 repeater (front=wire) → -1
  6gt[ST]: Re{n.2}
  10gt[PI]: Le{n.0}
  10gt[ST]: Co(c.2) p0     # z=3 comp: front=wire → 0
  12gt[ST]: Co{c.2}
}

state {
  t4  (2,1,0) comparator[facing=west,mode=compare,powered=true]    # -1 comp on (2gt)
  t6  (3,1,0) repeater[delay=1,facing=west,locked=false,powered=true]
  t6  (4,1,0) redstone_wire[east=side,north=none,power=15,south=none,west=side]
  t12 (2,1,3) comparator[facing=west,mode=compare,powered=true]    # 0 comp on (2gt)
  t12 (3,1,3) redstone_wire[east=side,north=none,power=15,south=none,west=side]
}
