# 観測でピストンを起動する連鎖: オブザーバーがダストの変化を検知し、その出力 (背面 strong 15)
# がピストンの背面を給電して伸長させ石を押す。オブザーバーは 2gt パルスのため、パルス OFF で
# ピストンは収縮する (短パルス収縮 = #82 で vanilla 一致)。
#
# 仕様クロスチェック (02 §6 observer / §6 piston / §4.1 PP [確定] + #80/#82):
#   §6 observer: PP を観測面 (facing=west) から受けて 2gt tile tick 予約 → ON→2gt後OFF の
#     2gt パルス。出力は背面 (OPPOSITE[facing]=east) 1 マスに strong 15。
#   §6 piston: OB on の NC (ST 相由来) → start delay 0 で同 tick 伸長 → 石を (4,1,0)→(5,1,0)。
#     伸長 moving は +2gt 後の t6 に確定 (#80 で BlockEntity 相)。
#   #82: OB off (t6) の収縮 BE が伸長中 (head=moving) に到達 → vanilla PistonBaseBlock.triggerEvent
#     が head の moving を finalTick (即確定) してから収縮。head 除去・石は (5,1,0) 残置、
#     base は収縮 moving 化し +2gt 後 (t8) に piston[extended=false] へ確定。
#   実機 fixture observer-piston-pulse で t4/t6/t8 系列を確認済み (sim=実機一致)。
meta {
  name: 観測でピストン起動 (オブザーバー 2gt パルス → 伸長し石を押し、パルス OFF で収縮)
  ref: 02 §6 observer / §6 piston / §4.1 PP / #80 / #82 / fixture observer-piston-pulse (実機一致)
}

circuit {
  (0,0,0)..(6,0,0) stone
  (0,1,0) lever[face=floor,facing=north,powered=false]
  (1,1,0) redstone_wire[east=side,north=none,power=0,south=none,west=side]
  (2,1,0) observer[facing=west,powered=false]
  (3,1,0) piston[extended=false,facing=east]
  (4,1,0) stone
}

inputs {
  t2 use (0,1,0)
}

ticks 10

state {
  t0 (2,1,0) observer[facing=west,powered=false]
  t0 (4,1,0) stone
  t0 (5,1,0) air
  # t4: OB パルス ON → piston 伸長開始
  t4 (2,1,0) observer[facing=west,powered=true]
  t4 (3,1,0) piston[extended=true,facing=east]
  # t6: OB パルス OFF (2gt 幅) + 収縮 BE が head を finalTick → 石が (5,1,0) 着地・head 除去、
  #     base は収縮 moving 化 (#82)
  t6 (2,1,0) observer[facing=west,powered=false]
  t6 (4,1,0) air
  t6 (5,1,0) stone
  # t8: base の収縮 moving が確定 → piston[extended=false]。石は (5,1,0) に恒久残置 (非粘着は引かない)
  t8 (3,1,0) piston[extended=false,facing=east]
  t8 (4,1,0) air
  t8 (5,1,0) stone
  t10 (3,1,0) piston[extended=false,facing=east]
  t10 (5,1,0) stone
}
