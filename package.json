{
  "name": "redstone-sim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "preview": "npm run preview -w app",
    "lint": "npm run lint -w app",
    "test": "vitest run",
    "test:watch": "vitest",
    "ground-truth": "bash tools/mc-harness/scripts/run-fixture.sh",
    "demo-gif": "node tools/demo/demo-gif.mjs",
    "e2e": "playwright test",
    "typecheck": "tsc -b packages/sim/tsconfig.json packages/editor/tsconfig.json packages/viewer/tsconfig.json",
    "harness:up": "DOCKER_API_VERSION=1.44 docker compose -f tools/mc-harness/docker-compose.yml up -d",
    "harness:down": "DOCKER_API_VERSION=1.44 docker compose -f tools/mc-harness/docker-compose.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "gifenc": "^1.0.3",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vitest": "^2.0.0"
  }
}
